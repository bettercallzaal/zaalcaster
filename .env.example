# zaalcaster / <username>caster env vars
#
# Local CLI: copy to ~/.zao/private/farcaster-zaal.env and fill in.
# Vercel: set these in the project's Environment Variables.
# Identity/branding (name, channels, voice, Daily) lives in config.js, not here.

# --- required ---
NEYNAR_API_KEY=your_neynar_api_key          # free at dev.neynar.com
USER_FID=your_farcaster_fid                 # (ZAAL_FID also accepted)

# --- posting (like/reply/cast) ---
SIGNER_UUID=your_neynar_signer_uuid         # mint with `npm run mint-signer` (ZAAL_SIGNER_UUID also accepted)

# --- optional: AI drafts + "what I missed" digest ---
OPENROUTER_API_KEY=your_openrouter_key

# --- optional: web app on Vercel ---
# Sign In With Farcaster (via Neynar's SIWN), replaces the old password gate.
# Anyone can sign in as themselves; you (USER_FID above) get full read+write,
# everyone else gets a read-only view (Feed/Channels/Search/Empire data only).
SESSION_SECRET=a_long_random_string         # signs the session cookie - required to turn the gate on
NEYNAR_CLIENT_ID=your_neynar_app_client_id  # Neynar dev portal > Settings; public, not secret
SPAM_LIST=user1,user2                       # comma-separated usernames/fids to hide from the inbox

# --- optional: cross-device sync + scheduled posts ---
# Add Vercel KV (Upstash) to auto-create KV_REST_API_URL + KV_REST_API_TOKEN.
CRON_SECRET=a_long_random_string            # protects /api/cron/post-due (scheduled posts)

# --- optional: create a tokenless empire from the Grow tab (Zaal-only) ---
# Adrian (Empire Builder) issued this key; it authorizes the server-side relay
# only - the actual owner wallet still signs client-side in the browser. This
# key alone can never deploy anything (no signature = Empire Builder rejects
# the call). See research doc 1092.
EMPIRE_BUILDER_API_KEY=your_empire_builder_key

# --- optional: ZOE integration (Zaal-only surfaces) ---
# The Daily tab's ZOE card (open tasks, mark-done, log-a-decision) reads the
# unified cowork tracker; "Ask ZAO" in cmd+k searches the Bonfire knowledge
# graph. Locally these load from ~/.zao/cowork-tracker.env + ~/.zao/zao.env
# automatically - set them here only for the Vercel deploy.
ZAO_TRACKER_URL=https://your-project.supabase.co
ZAO_TRACKER_KEY=your_supabase_service_key
BONFIRE_API_KEY=your_bonfire_key
BONFIRE_ID=your_bonfire_id
